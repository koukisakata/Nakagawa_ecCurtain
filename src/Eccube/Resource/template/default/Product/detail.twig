{% extends 'default_frame.twig' %}

{% set body_class = 'product_page' %}

{% block stylesheet %}
    <style>
        /* レイアウト調整 */
        .curtain-gallery-sticky { position: sticky; top: 20px; }
        .option-section, .option-group { margin-bottom: 30px; padding-top: 20px; border-top: 1px solid #eee; }
        .badge-req { background: #f0ad4e; color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 4px; vertical-align: middle; }
        .color-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 15px; }
        .color-chip input { display: none; }
        .chip-label { display: block; padding: 8px 4px; text-align: center; border: 1px solid #ddd; cursor: pointer; font-size: 11px; background: #fff; border-radius: 4px; }
        .color-chip input:checked + .chip-label { background-color: #333; color: #fff; border-color: #333; font-weight: bold; }
        input[type=range] { width: 100%; height: 8px; background: #ddd; border-radius: 5px; outline: none; margin: 10px 0; }
        #add_to_cart:disabled { background-color: #ccc !important; border-color: #ccc !important; cursor: not-allowed; opacity: 0.6; }
        .price-display-area { margin: 20px 0; padding: 15px; background: #f9f9f9; border-radius: 4px; }
        .ec-price { font-size: 24px; color: #d9534f; font-weight: bold; }
        .ec-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; display: flex; align-items: center; justify-content: center; }
        .ec-modal-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.6); }
        .ec-modal-wrap { position: relative; background: #fff; padding: 40px; border-radius: 8px; z-index: 10000; min-width: 300px; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.2); }
        .ec-modal-header { font-size: 18px; font-weight: bold; color: #333; margin-bottom: 20px; }
        .ec-modal-close { position: absolute; top: 10px; right: 15px; cursor: pointer; font-size: 20px; color: #999; }
    </style>
{% endblock %}

{% block javascript %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // PHPから送られたデバッグ情報を表示
            console.log("🚨 PHP デバッグ情報:", "{{ DebugCsv|raw }}");
            // 【重要】すでにJSON化されているので、json_encode フィルターは外します
            const curtainMatrix = {{ JsonMatrix|raw }};
            console.log("📦 展開されたマトリクス:", curtainMatrix);
            const priceDisplay = document.getElementById('display_price');
            const widthSlider = document.getElementById('slider-width');
            const heightSlider = document.getElementById('slider-height');
            const pleatsSelect = document.getElementById('opt-pleats');
            const memorySelect = document.getElementById('opt-memory');
            const agreeCheck = document.getElementById('agree_check');
            const cartBtn = document.getElementById('add_to_cart');
            
            let currentCalculatedPrice = 0;

            // --- detail.twig 内の window.syncToHiddenForm 関数を修正 ---
            // --- detail.twig 内の window.syncToHiddenForm 関数を以下に差し替え ---
            window.syncToHiddenForm = function() {
                console.log("--- 最終同期（真の最終版）を実行中 ---");
                const selectedRadio = document.querySelector('input[name="dummy_color_radio"]:checked');
                if (!selectedRadio) return;

                const classId = selectedRadio.dataset.classId; // 45
                const catId = selectedRadio.value; // 10
                const qty = document.getElementById('visible_quantity').value;

                const fillField = (targetName, value) => {
                    // [name="名前"] を正確に探し、あればその値を更新する
                    const el = document.querySelector(`#eccube_standard_form [name="${targetName}"]`);
                    if (el) {
                        el.value = value;
                        console.log("✅ 同期成功: " + targetName + " = " + value);
                    } else {
                        // もし名前が見つからない場合のみ、念のため新しく作る（保険）
                        const newEl = document.createElement('input');
                        newEl.type = 'hidden';
                        newEl.name = targetName;
                        newEl.value = value;
                        document.getElementById('eccube_standard_form').appendChild(newEl);
                        console.log("🛠️ フィールド作成: " + targetName);
                    }
                };

                // 【重要】ログで空だった "ProductClass" を最優先で埋める
                fillField('ProductClass', classId); 
                
                // コントローラ側が期待しているかもしれない名前も念のため埋める
                fillField('product_class_id', classId); 
                
                // 数量とカテゴリ
                fillField('quantity', qty);
                fillField('classcategory_id1', catId);

                // カーテン専用の隠しフィールド（ID指定なのでそのままでOK）
                const curtainFields = {
                    'hidden_curtain_width': 'slider-width',
                    'hidden_curtain_height': 'slider-height',
                    'hidden_curtain_pleats': 'opt-pleats',
                    'hidden_curtain_memory': 'opt-memory'
                };
                Object.keys(curtainFields).forEach(hid => {
                    const src = document.getElementById(curtainFields[hid]);
                    const target = document.getElementById(hid);
                    if (src && target) target.value = src.value;
                });
            };

            // --- 115行目付近の calculate() 関数内を修正 ---
            function calculate() {
                const w = parseInt(widthSlider.value);
                const h = parseInt(heightSlider.value);
                const pleats = pleatsSelect.value; 

                const labelW = document.getElementById('val-width');
                const labelH = document.getElementById('val-height');
                if (labelW) labelW.textContent = w;
                if (labelH) labelH.textContent = h;

                const selectedRadio = document.querySelector('input[name="dummy_color_radio"]:checked');
                if (!selectedRadio) {
                    priceDisplay.textContent = '品番未選択';
                    return;
                }

                const code = selectedRadio.dataset.code;
                const basePrice = parseFloat(selectedRadio.dataset.price) || 0; // SQLで入れた5000円を取得

                const colorNameDisplay = document.getElementById('display_color_name');
                if (colorNameDisplay) colorNameDisplay.textContent = selectedRadio.dataset.name;

                const wLimit = Math.ceil(w / 40) * 40;
                const hLimit = Math.ceil(h / 40) * 40;
                const pleatKey = parseFloat(pleats);

                let price = 0;
                
                console.log("--- 🔍 マトリクス検索開始 ---");
                console.log("1. 探す品番(code):", code);
                console.log("2. 探す幅(wLimit):", wLimit);
                console.log("3. 探す丈(hLimit):", hLimit);
                console.log("4. 探すヒダ(pleats):", pleats);
                console.log("📦 マトリクス全体:", curtainMatrix);

                try {
                    const row = curtainMatrix[code];
                    if (!row) {
                        console.warn("❌ 品番 [" + code + "] が見つかりません。");
                    } else {
                        const wData = row[wLimit];
                        if (!wData) {
                            console.warn("❌ 幅 [" + wLimit + "] が見つかりません。");
                        } else {
                            const hData = wData[hLimit];
                            if (!hData) {
                                console.warn("❌ 丈 [" + hLimit + "] が見つかりません。");
                            } else {
                                // ヒダ倍率で価格を取得
                                price = parseFloat(hData[pleats] || hData[parseFloat(pleats)] || 0);
                                if (price > 0) {
                                    console.log("✅ マトリクスから価格を取得成功！:", price);
                                } else {
                                    console.warn("❌ サイズは合いましたが、価格が0円になっています。データ:", hData);
                                }
                            }
                        }
                    }
                } catch (e) { 
                    console.error("🔥 マトリクス計算エラー:", e); 
                }

                // 2. マトリクスにない場合は、DBの基本価格をベースにする
                if (price === 0 && basePrice > 0) {
                    price = basePrice * (w / 100) * (h / 100);
                    console.log("💡 ベース価格(DB)から計算しました:", price);
                }

                if (price > 0) {
                    const memoryRate = parseFloat(memorySelect.options[memorySelect.selectedIndex].dataset.rate || 0);
                    price = price * pleatKey; // ヒダ倍率を掛ける
                    price += (price * memoryRate);
                    priceDisplay.textContent = '¥' + Math.floor(price).toLocaleString();
                    currentCalculatedPrice = Math.floor(price);
                } else {
                    priceDisplay.textContent = '価格未設定';
                    currentCalculatedPrice = 0;
                }

                window.syncToHiddenForm();
            }

            [widthSlider, heightSlider, pleatsSelect, memorySelect].forEach(el => el && el.addEventListener('input', calculate));
            document.querySelectorAll('input[name="dummy_color_radio"]').forEach(radio => radio.addEventListener('change', calculate));
            if(agreeCheck) agreeCheck.addEventListener('change', () => { cartBtn.disabled = !agreeCheck.checked; });

            calculate(); 
        });
    </script>

    <script>
        $(function() {
            $('.add-cart').on('click', function(event) {
                event.preventDefault();
                console.log("カートボタンが押されました。");
                
                // 送信直前に最終同期
                if (typeof window.syncToHiddenForm === 'function') {
                    window.syncToHiddenForm();
                }

                const $form = $('#form1');
                const curtainParams = $.param({
                    curtain_width: $('#slider-width').val(),
                    curtain_height: $('#slider-height').val(),
                    curtain_pleats: $('#opt-pleats').val(),
                    curtain_memory: $('#opt-memory').val()
                    curtain_price: currentCalculatedPrice
                });

                // 【修正点】product_id は必須でした！フィルタリングを完全にやめ、
                // EC-CUBEが生成した隠しフォームの中身を「そのまま」すべて送ります。
                const finalSerializedData = $('#eccube_standard_form :input').serialize();
                console.log("🔥 送信データ（product_id復活版）: ", finalSerializedData);

                $.ajax({
                    url: $form.attr('action') + '?' + curtainParams,
                    type: 'POST',
                    data: finalSerializedData,
                    dataType: 'json',
                    beforeSend: function() { $('.add-cart').prop('disabled', true); }
                }).done(function(data) {
                    // もし成功なら done: true が返ってきます
                    if (data.done) {
                        console.log("カート投入成功:", data);
                        $.each(data.messages, function() { $('#ec-modal-header').text(this); });
                        $('.ec-modal').show();
                        $.ajax({
                            url: "{{ url('block_cart') }}",
                            type: 'GET',
                            dataType: 'html'
                        }).done(function(html) { $('.ec-headerRole__cart').html(html); });
                    } else {
                        // done: false の場合（エラー）
                        console.error("バリデーションエラー:", data.messages);
                        alert(data.messages.join('\n'));
                    }
                }).fail(function(xhr) {
                    console.error("通信失敗:", xhr.responseText);
                    alert('システムエラーが発生しました。');
                }).always(function() { $('.add-cart').prop('disabled', false); });
            });
            $('.ec-modal-overlay, .ec-modal-close').on('click', () => { $('.ec-modal').hide(); });
        });
    </script>
{% endblock %}

{% block main %}
<div class="ec-productRole">
    <div class="ec-grid2">
        <div class="ec-grid2__cell ec-productRole__img">
            <div class="curtain-gallery-sticky">
                <div id="main_image_area" class="curtain-main-image">
                    <img src="{{ asset(Product.MainFileName|default('no_image.png'), 'save_image') }}" id="main_image">
                </div>
            </div>
        </div>

        <div class="ec-grid2__cell ec-productRole__description">
            <form name="form1" id="form1" method="post" action="{{ url('product_add_cart', {id:Product.id}) }}">
                <h1 class="ec-productRole__title">{{ Product.name }}</h1>
                
                <div class="price-display-area">
                    <p class="small text-muted">現在のカスタマイズ価格</p>
                    <span id="display_price" class="ec-price">¥0</span>
                    <span class="ec-tax">税込</span>
                </div>

                <div class="curtain-custom-options">
                    <section class="option-group">
                        <h3 style="display: flex; align-items: center; gap: 10px;">
                            品番： 
                            <span id="display_color_name" style="font-weight: normal; font-size: 14px; color: #333;">選択してください</span>
                            <span class="badge-req" style="margin-left: auto;">必須</span>
                        </h3>
                        <div class="color-grid">
                            {% set is_first_radio = true %}
                            {% for Class in Product.ProductClasses %}
                                {% if Class.code is not empty %}
                                    <label class="color-chip">
                                        <input type="radio" name="dummy_color_radio" 
                                            value="{{ Class.ClassCategory1 ? Class.ClassCategory1.id : '' }}" 
                                            data-class-id="{{ Class.id }}" 
                                            data-code="{{ Class.code }}" 
                                            data-price="{{ Class.price02|default(0)|number_format(0, '.', '') }}" {# ←ここを追加 #}
                                            data-name="{{ Class.ClassCategory1 ? Class.ClassCategory1.name : Class.code }}"
                                            {% if is_first_radio %}checked{% set is_first_radio = false %}{% endif %} required>
                                        <span class="chip-label">{{ Class.code }}</span>
                                    </label>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </section>

                    <section class="option-group">
                        <h3>サイズ選択</h3>
                        <div class="slider-container">
                            <p>幅：<strong id="val-width">100</strong>cm</p>
                            <input type="range" id="slider-width" min="40" max="400" value="100">
                            <p class="mt-3">丈：<strong id="val-height">100</strong>cm</p>
                            <input type="range" id="slider-height" min="40" max="300" value="100">
                        </div>
                    </section>

                    <div class="grid-2-col" style="display: flex; gap: 20px;">
                        <div style="flex:1;">
                            <h3>ヒダ形状</h3>
                            <select id="opt-pleats" class="form-control">
                                <option value="1.0">フラットカーテン</option>
                                <option value="1.5">1.5倍ひだ</option>
                                <option value="2.0">2.0倍ひだ</option>
                            </select>
                        </div>
                        <div style="flex:1;">
                            <h3>形態安定加工</h3>
                            <select id="opt-memory" class="form-control">
                                <option value="no" data-rate="0">なし</option>
                                <option value="yes" data-rate="0.1">あり (+10%)</option>
                            </select>
                        </div>
                    </div>

                    <div class="option-group">
                        <h3>数量</h3>
                        <input type="number" id="visible_quantity" value="1" min="1" class="form-control" style="width: 100px;">
                    </div>

                    <section class="cart-action-area mt-5" style="border-top: 2px solid #333; padding-top: 20px;">
                        <label class="caution-check" style="display: block; margin-bottom: 20px;">
                            <input type="checkbox" id="agree_check">
                            <span style="font-weight: bold; margin-left: 8px;">ご注意事項を確認しました</span>
                        </label>
                        <button type="submit" id="add_to_cart" class="btn-cart add-cart ec-blockBtn--action" style="width:100%; padding:20px;" disabled>
                            カートに入れる
                        </button>
                    </section>
                </div>

                <div style="display: none;" id="eccube_standard_form_wrapper">
                    <div id="eccube_standard_form">
                        {{ form_widget(form) }}
                        {# ← ここにあった curtain_width などを削除 #}
                    </div>
                    {# --- ここ（formの枠の外）に移動させる --- #}
                    <input type="hidden" id="hidden_curtain_width">
                    <input type="hidden" id="hidden_curtain_height">
                    <input type="hidden" id="hidden_curtain_pleats">
                    <input type="hidden" id="hidden_curtain_memory">
                </div>
            </form>
        </div>
    </div>
</div>

<div class="ec-modal" style="display:none;">
    <div class="ec-modal-overlay"></div>
    <div class="ec-modal-wrap">
        <div class="ec-modal-close">×</div>
        <div class="ec-modal-header" id="ec-modal-header">カートに追加しました。</div>
        <div style="margin-top: 20px;">
            <a href="{{ url('cart') }}" class="btn-cart ec-blockBtn--action" style="padding: 10px 20px; background: #333; color: #fff; text-decoration: none; border-radius: 4px;">カートを見る</a>
        </div>
    </div>
</div>
{% endblock %}