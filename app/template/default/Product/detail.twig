                                {% set interior_haki_main = ['LM_I_BK.png', 'LM_I_BR.png', 'LM_I_WH.png'] %}
                                {% for img in interior_haki_main %}
                                    <div class="col-6 col-md-4 mb-3">
                                        <input type="radio" name="interior_haki_main_radio" id="int_haki_main_{{ loop.index }}" value="{{ img }}" {% if loop.first %}checked{% endif %}>
