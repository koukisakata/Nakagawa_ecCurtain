                            <button type="button" id="btn-width-minus" class="btn btn-outline-secondary rounded-circle btn-circle shadow-sm fw-black">－</button>
                            <input type="range" id="slider-width" min="40" max="400" value="100" class="slider-custom flex-grow-1 mx-3">
                            <button type="button" id="btn-width-plus" class="btn btn-outline-secondary rounded-circle btn-circle shadow-sm fw-black">＋</button>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex align-items-baseline mb-2"><span class="fw-black text-dark mr-2">サイズ丈：</span><span id="val-height" class="h5 mb-0 fw-black">100</span><span class="ml-1 small fw-black text-dark">cm</span></div>
