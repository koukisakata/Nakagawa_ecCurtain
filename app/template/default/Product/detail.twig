                        <div class="col-4 mb-2"><input type="radio" name="pleats_radio" id="pleats_2" value="1.5" data-name="1.5倍ヒダ"><label for="pleats_2" class="d-block bg-white overflow-hidden p-0 mb-0 position-relative"><img src="{{ asset('assets/img/curtain/15.png') }}" class="img-fluid w-100"></label></div>
                        <div class="col-4 mb-2"><input type="radio" name="pleats_radio" id="pleats_3" value="2.0" data-name="2.0倍ヒダ"><label for="pleats_3" class="d-block bg-white overflow-hidden p-0 mb-0 position-relative"><img src="{{ asset('assets/img/curtain/20.png') }}" class="img-fluid w-100"></label></div>
                    </div>
                </div>

                {# フック選択 #}
                <div class="bg-white border border-dark rounded p-4 mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 fw-black mb-3">
                            フック： <span id="display_hook_name" class="fw-black text-dark ml-2">Aフック</span>
                        </h3>
                        <span class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-black shadow-sm" style="width: 22px; height: 22px; font-size: 0.85rem; cursor: pointer;">?</span>
                    </div>
                    <div class="row row-tight custom-radio-img">
                        <div class="col-6 mb-2"><input type="radio" name="hook_radio" id="hook_1" value="Aフック" checked><label for="hook_1" class="d-block bg-white overflow-hidden p-0 mb-0 position-relative"><img src="{{ asset('assets/img/curtain/Aフック.png') }}" class="img-fluid w-100"></label></div>
                        <div class="col-6 mb-2"><input type="radio" name="hook_radio" id="hook_2" value="Bフック"><label for="hook_2" class="d-block bg-white overflow-hidden p-0 mb-0 position-relative"><img src="{{ asset('assets/img/curtain/Bフック.png') }}" class="img-fluid w-100"></label></div>
                    </div>
                </div>

                {# 形態安定オプション #}
                <div class="bg-white border border-dark rounded p-4 mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                        <h3 class="h6 fw-black mb-0">形態安定加工</h3>
                        <span class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-black shadow-sm" style="width: 22px; height: 22px; font-size: 0.85rem; cursor: pointer;">?</span>
                    </div>
                    <select id="opt-memory" class="custom-select w-100 fw-black text-dark" style="height: 3.2rem; border: 1px solid #ddd; font-size: 1rem;">
                        <option value="no" data-rate="0">なし</option>
                        <option value="yes" data-rate="0.1">あり (+10%)</option>
                    </select>
                </div>

                {# カスタムカーテン設定 #}
                <div class="bg-white border border-dark rounded p-4 mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 fw-black mb-0">
                            カスタムカーテン： <span id="display_custom_curtain_name" class="fw-black text-dark ml-2">選択してください</span>
                        </h3>
                        <span class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-black shadow-sm" style="width: 22px; height: 22px; font-size: 0.85rem; cursor: pointer;">?</span>
                    </div>
                    
                    <select id="opt-custom-curtain" class="custom-select w-100 fw-black text-dark mb-4" style="height: 3.2rem; border: 1px solid #ddd; font-size: 1rem;">
                        <option value="" hidden selected>選択してください</option>
                        <option value="なし">なし</option>
                        <option value="ロックトリミング">ロックトリミング</option>
                        <option value="カスタムスタイル">カスタムスタイル</option>
                    </select>

                    <div id="thread-color-option-area" style="display: none;">
                        <h3 class="h6 fw-black mb-3 border-top pt-3">
                            糸のカラー： <span id="display_custom_curtain_color_name" class="fw-black text-dark ml-2">選択してください</span>
                        </h3>
                        
                        {% set thread_colors = [
                            {'code': 'white', 'name': 'ホワイト'}, {'code': 'ivory', 'name': 'アイボリー'},
                            {'code': 'beige', 'name': 'ベージュ'}, {'code': 'lightgreen', 'name': 'ライトグリーン'},
                            {'code': 'green', 'name': 'グリーン'}, {'code': 'blue', 'name': 'ブルー'},
                            {'code': 'yellow', 'name': 'イエロー'}, {'code': 'orange', 'name': 'オレンジ'},
                            {'code': 'pink', 'name': 'ピンク'}, {'code': 'red', 'name': 'レッド'},
                            {'code': 'wine', 'name': 'ワインレッド'}, {'code': 'brown', 'name': 'ブラウン'}
                        ] %}

                        <div class="row row-tight custom-radio-img">
                            {% for Thread in thread_colors %}
                                <div class="col-4 col-sm-3 col-md-2 mb-2">
                                    <input type="radio" name="custom_curtain_color_radio" id="cc_col_{{ loop.index }}" value="{{ Thread.name }}" data-name="{{ Thread.name }}" required>
                                    <label for="cc_col_{{ loop.index }}" class="d-block bg-white rounded overflow-hidden p-0 mb-1 position-relative w-100 text-center">
                                        <div style="position: relative; width: 100%; padding-bottom: 100%;">
                                            <img src="/html/template/default/assets/img/curtain/chips/thread_{{ Thread.code }}_chip.png" onerror="this.src='/upload/save_image/no_image.png';this.onerror=null;" class="img-fluid" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                                        </div>
                                    </label>
                                    <div class="small text-muted fw-black text-center" style="font-size: 0.7rem;">{{ Thread.name }}</div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div id="custom-style-option-area" style="display: none;">
                        <h3 class="h6 fw-black mb-3 border-top pt-3 mt-2">
                            カスタム位置： <span id="display_custom_style_position" class="fw-black text-dark ml-2">トップ</span>
                        </h3>
                        <div class="row row-tight custom-radio-img mb-4">
                            <div class="col-4 mb-2"><input type="radio" name="custom_style_position_radio" id="csp_1" value="トップ" data-name="トップ" checked><label for="csp_1" class="d-block bg-white overflow-hidden p-0 mb-1 position-relative"><img src="{{ asset('assets/img/curtain/top_custom.png') }}" class="img-fluid w-100"></label><div class="small text-muted fw-black text-center mt-1" style="font-size: 0.7rem;">トップ</div></div>
                            <div class="col-4 mb-2"><input type="radio" name="custom_style_position_radio" id="csp_2" value="センター" data-name="センター"><label for="csp_2" class="d-block bg-white overflow-hidden p-0 mb-1 position-relative"><img src="{{ asset('assets/img/curtain/center_custom.png') }}" class="img-fluid w-100"></label><div class="small text-muted fw-black text-center mt-1" style="font-size: 0.7rem;">センター</div></div>
                            <div class="col-4 mb-2"><input type="radio" name="custom_style_position_radio" id="csp_3" value="ボトム" data-name="ボトム"><label for="csp_3" class="d-block bg-white overflow-hidden p-0 mb-1 position-relative"><img src="{{ asset('assets/img/curtain/bottom_custom.png') }}" class="img-fluid w-100"></label><div class="small text-muted fw-black text-center mt-1" style="font-size: 0.7rem;">ボトム</div></div>
                        </div>

                        <h3 class="h6 fw-black mb-3">
                            コンビネーションカラー： <span id="display_combination_color_name" class="fw-black text-dark ml-2">選択してください</span>
                        </h3>
                        <div class="row row-tight custom-radio-img" id="combination-color-list">
                            {% set is_first_comb = true %}
                            {% for Class in Product.ProductClasses %}
                                {% if Class.code is not empty %}
                                    <div class="col-4 col-sm-3 col-md-2 mb-2 combination-color-item" data-code="{{ Class.code }}">
                                        <input type="radio" name="combination_color_radio" id="comb_{{ loop.index }}" value="{{ Class.ClassCategory1 ? Class.ClassCategory1.name : Class.code }}" data-name="{{ Class.ClassCategory1 ? Class.ClassCategory1.name : Class.code }}" {% if is_first_comb %}checked{% set is_first_comb = false %}{% endif %}>
                                        <label for="comb_{{ loop.index }}" class="d-block bg-white rounded overflow-hidden p-0 mb-1 position-relative w-100 text-center">
                                            <div style="position: relative; width: 100%; padding-bottom: 100%;">
                                                <img src="/html/template/default/assets/img/curtain/chips/{{ Class.code }}_chip.png" onerror="this.src='/upload/save_image/no_image.png';this.onerror=null;" class="img-fluid" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                                            </div>
                                        </label>
                                        <div class="small text-muted fw-black text-center" style="font-size: 0.7rem;">{{ Class.code }}</div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# タッセル選択 #}
                <div class="bg-white border border-dark rounded p-4 mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 fw-black mb-3">
                            タッセル： <span id="display_tassel_name" class="fw-black text-dark ml-2">共生地タッセル</span>
                        </h3>
                        <span class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-black shadow-sm" style="width: 22px; height: 22px; font-size: 0.85rem; cursor: pointer;">?</span>
                    </div>
                    <div class="row row-tight custom-radio-img">
                        <div class="col-6 col-md-3 mb-2 tassel-item" data-compatible-fabrics="all">
                            <input type="radio" name="tassel_radio" id="tassel_0" value="共生地タッセル" data-price="0" data-name="共生地タッセル" checked>
                            <label for="tassel_0" class="d-block bg-white overflow-hidden mb-0 position-relative">
                                <img src="{{ asset(Product.MainFileName|default('no_image.png'), 'save_image') }}" id="img-tassel-matching" class="img-fluid w-100">
                                <div class="text-center bg-light border-top p-1 fw-black" style="font-size: 0.65rem;" id="text-tassel-matching">共生地</div>
                            </label>
                        </div>
                        {% for Tassel in TasselProducts %}
                            <div class="col-6 col-md-3 mb-2 tassel-item" data-compatible-fabrics="{{ Tassel.search_word|default('all') }}">
                                <input type="radio" name="tassel_radio" id="tassel_{{ loop.index }}" value="{{ Tassel.name }}" data-price="{{ Tassel.getPrice02Min }}" data-name="{{ Tassel.name }}">
                                <label for="tassel_{{ loop.index }}" class="d-block bg-white overflow-hidden mb-0 position-relative"><img src="{{ asset(Tassel.MainFileName|default('no_image.png'), 'save_image') }}" class="img-fluid w-100"><div class="text-center bg-light border-top p-1 fw-black" style="font-size: 0.65rem;">{{ Tassel.name }}</div></label>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {# 注意事項（同意チェック） #}
                <div class="bg-white border border-dark rounded p-4 mb-4 shadow-sm">
                    <label class="d-block mb-0 text-center" style="cursor: pointer;">
                        <input type="checkbox" id="agree_check" class="mr-2">
                        <span class="fw-black text-danger">オーダー品のため返品不可となります。ご注意事項を確認しました。</span>
                    </label>
                </div>
                
                {# サマリー表示（価格・カートボタン） #}
                <div class="bg-white mb-3">
                    <h3 class="h6 fw-black mb-3 pb-2">
                        品番： <span class="display-color-name fw-black text-dark ml-2">選択してください</span>
                    </h3>
                    <div class="d-flex align-items-center mb-3">
                        <span class="fw-black text-dark mr-3" style="font-size: 1rem;">数量</span>
                        <input type="number" value="1" min="1" class="form-control text-center fw-black visible-quantity" style="width: 80px; font-size: 1.2rem; border-color: #ccc;">
                    </div>
                    <div class="d-flex align-items-baseline mb-4">
                        <span class="display-price h2 font-weight-bold text-danger my-0">¥0</span>
                        <span class="ml-2 font-weight-bold small text-dark">税込</span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-block fw-black add-cart add_to_cart_btn shadow-sm w-100" style="background-color: #e24545; color: #fff; padding: 1.2rem; border-radius: 8px; font-size: 1.2rem; border: none;" disabled>
                            <i class="fa fa-shopping-cart mr-2"></i>カートに入れる
                        </button>
                    </div>
                </div>
                
                {# 見積り・サンプル請求等のリンクボタン群 #}
                <div class="bg-white container px-0">
                    <div class="row d-flex justify-content-between pb-3">
                        <div class="col-6">
                            <button class="btn btn-dark text-white w-100 px-0 py-2 fw-black">見積りが欲しい方</button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-dark text-white w-100 px-0 py-2 fw-black">
                                <i class="far fa-clone fa-xs"></i> サンプル生地が欲しい方
                            </button>
                        </div>
                    </div>
                    <div class="row d-flex justify-content-between">
                        <div class="col-12">
                            <button class="btn btn-outline-dark w-100 px-0 py-2 fw-black">
                                <i class="fas fa-file-alt"></i> この商品について問い合わせる
                            </button>
                        </div>
                    </div>
                    <div class="row py-3">
                        <div class="col-12">
                            <button type="button" class="btn btn-info w-100 p-0 text-left border-0 shadow-sm overflow-hidden" style="border-radius: 8px;">
                                <div class="row m-0 h-100 align-items-stretch justify-content-end">
                                    <div class="col-8 col-sm-8 py-3 pl-3 pr-2 d-flex flex-column justify-content-center">
                                        <span class="mb-1 font-weight-bold" style="font-size: 0.75rem; color: rgba(255,255,255,0.9);">どんな些細なことでもプロが親切に対応します!</span>
                                        <span class="mb-0 fw-black text-white" style="font-size: 1.05rem; line-height: 1.4;">見積り・サンプル・出張採寸はこちら</span>
                                    </div>
                                    <div class="col-4 col-sm-3 p-0 position-relative d-flex align-items-center justify-content-center">
                                        <img src="/html/template/default/assets/img/curtain/istock.png" class="w-50" style="object-fit: cover; max-height: 100%;" alt="対応イメージ">
                                    </div>
                                </div>
                            </button>
                        </div>
                    </div>
                </div>

                {# EC-CUBEの裏側に送信する隠しフォーム #}
                <div class="d-none" id="eccube_standard_form_wrapper">
                    <div id="eccube_standard_form">{{ form_widget(form) }}</div>
                    {% for k in ['width','height','pleats','memory','open','hook','tassel','custom','custom_color', 'custom_style_position', 'custom_combination_color'] %}<input type="hidden" id="hidden_curtain_{{k}}">{% endfor %}
                </div>

                {# 下部固定のフローティング・カートバー #}
                <div class="fixed-bottom shadow-lg" style="background-color: #FFFDE8; border-top: 1px solid #f0e9cd; z-index: 1100;">
                    <div class="container py-2 py-md-3">
                        <div class="row align-items-center justify-content-center justify-content-md-end">
                            <div class="col-12 col-md-auto d-flex justify-content-center align-items-center mb-2 mb-md-0">
                                <div class="d-flex align-items-center mr-4">
                                    <span class="fw-black text-dark mr-2" style="font-size: 1rem;">数量</span>
                                    <input type="number" value="1" min="1" class="form-control text-center fw-black visible-quantity" style="width: 70px; font-size: 1.2rem; border-color: #ccc;">
                                </div>
                                <div class="d-flex align-items-baseline">
                                    <span class="display-price fw-black" style="font-size: 2.2rem; color: #e24545; line-height: 1;">¥0</span>
                                    <span class="fw-black text-dark ml-2" style="font-size: 0.9rem;">税込</span>
                                </div>
                            </div>
                            <div class="col-12 col-md-auto">
                                <button type="submit" id="add_to_cart" class="btn btn-block fw-black add-cart add_to_cart_btn shadow-sm" style="background-color: #e24545; color: #fff; padding: 0.8rem 3rem; border-radius: 6px; font-size: 1.1rem; border: none;" disabled><i class="fa fa-shopping-cart mr-2"></i>カートに入れる</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

{# カート投入後の完了モーダル #}
<div class="modal fade" id="cartModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header border-0 pb-0"><button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button></div>
            <div class="modal-body text-center pb-5 pt-2">
                <h5 class="font-weight-bold mb-4" id="ec-modal-header">カートに追加しました。</h5>
                <a href="{{ url('cart') }}" class="btn btn-dark px-5 py-2 font-weight-bold rounded">カートを見る</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}