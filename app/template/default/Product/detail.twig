                                            <div style="position: relative; width: 100%; padding-bottom: 75%;">
                                                <img src="/html/template/default/assets/img/room/{{ img }}" onerror="this.style.display='none'" class="img-fluid" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" alt="インテリア">
                                            </div>
                                        </label>
                                    </div>
                                {% endfor %}
