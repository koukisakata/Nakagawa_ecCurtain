                                        <label for="int_koshi_bed_cover_{{ loop.index }}" class="no-check d-block bg-white overflow-hidden p-0 mb-0 position-relative w-100 text-center shadow-sm" style="border: 1px solid #ddd; border-radius: 4px;">
                                            <div style="position: relative; width: 100%; padding-bottom: 75%;">
