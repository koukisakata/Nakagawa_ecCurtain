                            <div class="row row-tight custom-radio-img mb-4">
                                {% set interior_haki_table = [
                                    'LM_T01_BE.png', 'LM_T01_BK.png', 'LM_T01_WH.png',
                                    'LM_T02_BE.png', 'LM_T02_BK.png', 'LM_T02_WH.png'
