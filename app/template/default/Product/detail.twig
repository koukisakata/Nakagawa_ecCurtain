            <form name="form1" id="form1" method="post" action="{{ url('product_add_cart', {id:Product.id}) }}">
                {% if Product.Tags is not empty %}
                    <div class="mb-3 d-flex flex-wrap">
                        {% for Tag in Product.Tags %}
                            {% set badge_class = 'badge p-2 mx-1 mb-2 fw-black shadow-sm' %}
                            {% set inline_style = 'font-size: 0.8rem;' %}
                            {% if Tag.name == 'おすすめ商品' %}
                                {% set inline_style = inline_style ~ ' background-color: #f7df26; color: #000; border-radius: 20px;' %}
                            {% elseif Tag.name == '遮光1級' %}
                                {% set inline_style = inline_style ~ ' background-color: #fff; color: #000; border: 1px solid #000; border-radius: 20px;' %}
                            {% elseif Tag.name == '即日配送' %}
                                {% set inline_style = inline_style ~ ' background-color: #62c3e2; color: #fff; border-radius: 20px;' %}
                            {% elseif Tag.name == 'カスタムカーテン' %}
                                {% set inline_style = inline_style ~ ' background-color: #f78da7; color: #fff; border-radius: 20px;' %}
                            {% else %}
                                {% set badge_class = badge_class ~ ' badge-dark' %}
                                {% set inline_style = inline_style ~ ' color: #fff;' %}
                            {% endif %}
                            <span class="{{ badge_class }}" style="{{ inline_style }}">{{ Tag.name }}</span>
                        {% endfor %}
                    </div>
                {% endif %}

                <h1 class="h3 fw-black mb-2">{{ Product.name }}</h1>

                {% if Product.description_detail is not empty %}
                    <div class="mb-4 text-dark bg-white" style="font-size: 0.95rem; line-height: 1.8;">
                        {{ Product.description_detail|raw }}
