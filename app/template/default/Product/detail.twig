                                    <label for="col_{{ loop.index }}" class="d-block bg-white overflow-hidden p-0 mb-1 position-relative w-100 text-center">
                                        <div style="position: relative; width: 100%; padding-bottom: 100%;"><img src="/html/template/default/assets/img/curtain/chips/{{ Class.code }}_chip.png" onerror="this.src='/upload/save_image/no_image.png';this.onerror=null;" class="img-fluid" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;"></div>
                                    </label>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                {# 開き方選択 #}
